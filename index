<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Thibault Gaborit — Portfolio Adjoint</title>

<style>

  /* FALLBACK GLOBAL */
  * { box-sizing: border-box; }
  body, div, p, span, li, a { color: inherit; }
  h1, h2, h3, h4, h5, h6 { color: #f4f4ee; }

  :root {
    color-scheme: dark;
    --noir: #080b08;
    --vert-fonce: #0b1a0b;
    --vert-mid: #152815;
    --vert-accent: #2a5a2a;
    --vert-vif: #4a9e4a;
    --vert-clair: #6abf6a;
    --blanc: #f4f4ee;
    --gris-clair: #c5c5bc;
    --gris-mid: #7a7a72;
    --or: #c8a84b;
    --or-clair: #e0c068;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { background: #080b08 !important; color: #f4f4ee !important; font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif; font-weight: 300; overflow-x: hidden; }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 1rem 4rem; background: rgba(8,11,8,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.05); }
  .nav-logo { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 1.2rem; letter-spacing: 0.2em; color: var(--vert-vif); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { color: var(--gris-mid); text-decoration: none; font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; transition: color 0.2s; }
  .nav-links a:hover { color: var(--blanc); }

  /* LAYOUT */
  .slide { min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden; }
  .slide-inner { width: 100%; max-width: 1280px; margin: 0 auto; padding: 7rem 4rem 4rem; }
  .section-label { font-size: 0.62rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--vert-vif); margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.8rem; }
  .section-label::after { content: ''; display: block; height: 1px; width: 2.5rem; background: var(--vert-vif); }
  .slide-title { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: clamp(2.8rem, 5vw, 5rem); line-height: 0.92; letter-spacing: 0.02em; margin-bottom: 3rem; }
  .fade-in { opacity: 1; transform: translateY(0); transition: opacity 0.65s ease, transform 0.65s ease; }
  .fade-in.visible { opacity: 1; transform: translateY(0); }

  /* COVER */
  #cover { background: var(--vert-fonce); }

  #cover-bg {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    overflow: hidden;
    z-index: 1;
  }
  #cover-bg img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: 35% center;
    opacity: 0.35;
  }
  #cover-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--vert-fonce) 0%, transparent 40%);
  }
  #cover-bg-OLD { display:none;background-image:url("data:image/jpeg;base64,");background-size:cover;background-position:center 15%;opacity:0.30;pointer-events:none;z-index:1; }
  #cover .slide-inner { position:relative;z-index:2; }
  #cover::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 70% at 75% 40%, rgba(42,90,42,0.3) 0%, transparent 65%), radial-gradient(ellipse 30% 50% at 10% 90%, rgba(74,158,74,0.07) 0%, transparent 60%); pointer-events: none; }
  #cover::after { content: 'TG'; position: absolute; right: -1.5rem; bottom: -5rem; font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 30vw; color: rgba(255,255,255,0.018); line-height: 1; pointer-events: none; user-select: none; }
  .cover-grid { position: relative; z-index: 2; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 5rem; align-items: center; }
  .cover-tag { display: inline-flex; align-items: center; gap: 0.6rem; font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--vert-vif); border: 1px solid rgba(74,158,74,0.4); padding: 0.3rem 0.9rem; margin-bottom: 2rem; }
  .cover-tag::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--vert-vif); flex-shrink: 0; }
  .cover-name { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: clamp(4rem, 7.5vw, 8rem); line-height: 0.88; letter-spacing: 0.02em; margin-bottom: 1.8rem; }
  .cover-name span { display: block; color: var(--vert-vif); }
  .cover-tagline { font-family: 'Playfair Display', serif; font-style: italic; font-size: clamp(0.95rem, 1.6vw, 1.25rem); color: var(--gris-clair); line-height: 1.6; max-width: 460px; margin-bottom: 2.5rem; }
  .cover-contacts { display: flex; flex-direction: column; gap: 0.5rem; }
  .cover-contact { display: flex; align-items: center; gap: 0.7rem; font-size: 0.78rem; color: var(--gris-mid); }
  .cover-contact .dot { width: 3px; height: 3px; border-radius: 50%; background: var(--vert-vif); flex-shrink: 0; }
  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.06); }
  .stat-cell { background: rgba(11,26,11,0.85); padding: 1.8rem 1.5rem; text-align: center; }
  .stat-cell .s-num { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 3rem; color: var(--vert-vif); line-height: 1; display: block; }
  .stat-cell .s-label { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gris-mid); margin-top: 0.3rem; display: block; line-height: 1.4; }

  /* PROFIL */
  #profil { background: var(--noir); }
  #profil .slide-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .profil-text { font-size: 0.92rem; line-height: 1.8; color: var(--gris-clair); margin-bottom: 1.4rem; }
  .profil-text strong { color: var(--blanc); font-weight: 500; }
  .diplomes { margin-top: 2rem; border: 1px solid rgba(255,255,255,0.06); border-left: 2px solid var(--vert-vif); }
  .diplome-row { display: flex; justify-content: space-between; align-items: center; padding: 0.9rem 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.82rem; }
  .diplome-row:last-child { border-bottom: none; }
  .diplome-row .d-label { color: var(--gris-clair); }
  .badge { font-size: 0.58rem; padding: 0.18rem 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; }
  .badge.ok { background: rgba(74,158,74,0.12); color: var(--vert-vif); }
  .badge.wip { background: rgba(200,168,75,0.12); color: var(--or); }
  .forces { display: flex; flex-direction: column; }
  .force-row { display: grid; grid-template-columns: 2.5rem 1fr; gap: 1rem; padding: 1.1rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); align-items: start; }
  .force-num { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 2rem; color: rgba(74,158,74,0.2); line-height: 1; }
  .force-content .fc-title { font-size: 0.86rem; font-weight: 500; color: var(--blanc); margin-bottom: 0.2rem; }
  .force-content .fc-sub { font-size: 0.72rem; color: var(--gris-mid); line-height: 1.4; }

  /* PARCOURS */
  #parcours { background: var(--vert-fonce); }
  .parcours-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 4rem; align-items: start; }
  .timeline { padding-left: 1.5rem; position: relative; }
  .timeline::before { content: ''; position: absolute; left: 0; top: 0.6rem; bottom: 0; width: 1px; background: linear-gradient(to bottom, rgba(74,158,74,0.5), rgba(74,158,74,0.05)); }
  .tl-item { padding: 0 0 2.5rem 2.5rem; position: relative; }
  .tl-item::before { content: ''; position: absolute; left: -0.35rem; top: 0.5rem; width: 0.7rem; height: 0.7rem; border-radius: 50%; background: var(--vert-accent); border: 1.5px solid var(--vert-vif); }
  .tl-period { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--vert-vif); margin-bottom: 0.3rem; }
  .tl-club { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 1.5rem; letter-spacing: 0.04em; margin-bottom: 0.2rem; }
  .tl-role { font-size: 0.75rem; color: var(--gris-mid); margin-bottom: 0.7rem; }
  .tl-pts { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
  .tl-pts li { font-size: 0.8rem; color: var(--gris-clair); line-height: 1.45; display: flex; gap: 0.5rem; align-items: flex-start; }
  .tl-pts li::before { content: '—'; color: rgba(74,158,74,0.5); flex-shrink: 0; font-size: 0.7rem; margin-top: 0.08rem; }

  /* Thonon card */
  .thonon-card { background: rgba(21,40,21,0.6); border: 1px solid rgba(74,158,74,0.18); padding: 2rem; }
  .thonon-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
  .thonon-header .th-title { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 1.8rem; letter-spacing: 0.04em; }
  .thonon-header .th-period { font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--or); margin-top: 0.2rem; }
  .thonon-header .th-badge { font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; background: rgba(74,158,74,0.1); color: var(--vert-vif); border: 1px solid rgba(74,158,74,0.25); padding: 0.3rem 0.7rem; white-space: nowrap; }
  .preuves-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.06); margin-bottom: 1.5rem; }
  .preuve-cell { background: rgba(11,26,11,0.7); padding: 1.2rem; }
  .preuve-cell .pc-label { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gris-mid); margin-bottom: 0.4rem; display: block; }
  .preuve-cell .pc-value { font-size: 0.82rem; color: var(--blanc); line-height: 1.45; }
  .preuve-cell .pc-value strong { color: var(--vert-clair); font-weight: 500; }
  .thonon-missions { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
  .thonon-missions li { font-size: 0.78rem; color: var(--gris-clair); line-height: 1.4; display: flex; gap: 0.5rem; align-items: flex-start; }
  .thonon-missions li::before { content: '›'; color: var(--vert-vif); flex-shrink: 0; }

  /* IDENTITÉ */
  #identite { background: var(--noir); }
  #identite::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 55% 70% at 95% 50%, rgba(42,90,42,0.1) 0%, transparent 65%); pointer-events: none; }
  .identite-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5rem; align-items: start; }
  .mantra { font-family: 'Playfair Display', serif; font-style: italic; font-size: clamp(1.6rem, 2.8vw, 2.4rem); line-height: 1.3; color: var(--blanc); margin-bottom: 2rem; }
  .mantra em { color: var(--vert-vif); font-style: normal; }
  .trois-mots { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,0.06); margin-bottom: 2rem; }
  .mot-cell { background: var(--noir); padding: 1.3rem 0.8rem; text-align: center; }
  .mot-cell .mot { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 1.35rem; letter-spacing: 0.06em; color: var(--blanc); display: block; }
  .mot-cell .mot-sub { font-size: 0.62rem; color: var(--gris-mid); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.3rem; display: block; }
  .refs-block { padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.06); }
  .refs-label { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gris-mid); margin-bottom: 1rem; }
  .refs-items { display: flex; flex-direction: column; gap: 0.8rem; }
  .ref-item .ri-name { font-weight: 500; font-size: 0.88rem; color: var(--blanc); }
  .ref-item .ri-detail { font-size: 0.72rem; color: var(--gris-mid); margin-top: 0.15rem; }
  .cadres-block { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 1.8rem; margin-bottom: 1.5rem; }
  .cadres-block .cb-title { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 0.9rem; letter-spacing: 0.1em; color: var(--vert-vif); margin-bottom: 1rem; }
  .cadre-item { padding: 0.7rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .cadre-item:last-child { border-bottom: none; }
  .cadre-item .ci-name { font-size: 0.84rem; font-weight: 500; color: var(--blanc); }
  .cadre-item .ci-app { font-size: 0.72rem; color: var(--gris-mid); margin-top: 0.18rem; line-height: 1.4; }
  .vision-block { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 1.8rem; }
  .vision-block .vb-title { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 0.9rem; letter-spacing: 0.1em; color: var(--vert-vif); margin-bottom: 0.8rem; }
  .vision-block p { font-size: 0.84rem; color: var(--gris-clair); line-height: 1.7; }

  /* RÔLE */
  #role { background: var(--vert-fonce); }
  .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5rem; }
  .citation { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.15rem; line-height: 1.65; color: var(--gris-clair); padding-left: 1.4rem; border-left: 2px solid var(--vert-vif); margin-bottom: 2.2rem; }
  .piliers { display: flex; flex-direction: column; gap: 1px; background: rgba(255,255,255,0.04); }
  .pilier { background: var(--vert-fonce); padding: 1.2rem 1.5rem; display: grid; grid-template-columns: 2.2rem 1fr; gap: 1rem; align-items: start; }
  .pilier-num { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 1.8rem; color: rgba(74,158,74,0.2); line-height: 1; }
  .pilier .p-title { font-size: 0.82rem; font-weight: 500; color: var(--blanc); margin-bottom: 0.25rem; }
  .pilier p { font-size: 0.76rem; color: var(--gris-mid); line-height: 1.5; }
  .interventions { display: flex; flex-direction: column; gap: 0.6rem; }
  .intv { display: grid; grid-template-columns: 2.2rem 1fr; gap: 1rem; align-items: center; padding: 0.9rem 1rem; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); transition: border-color 0.2s; }
  .intv:hover { border-color: rgba(74,158,74,0.25); }
  .intv-ico { width: 2rem; height: 2rem; background: rgba(74,158,74,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; }
  .intv-t { font-size: 0.82rem; font-weight: 500; color: var(--blanc); }
  .intv-d { font-size: 0.7rem; color: var(--gris-mid); margin-top: 0.1rem; }

  /* OUTILS */
  #outils { background: var(--noir); }
  .outils-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,0.05); margin-bottom: 2rem; }
  .outil-card { background: var(--noir); padding: 2rem; }
  .outil-card .oc-icon { font-size: 1.4rem; margin-bottom: 1rem; display: block; }
  .outil-card .oc-title { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 1rem; letter-spacing: 0.1em; color: var(--blanc); margin-bottom: 0.8rem; }
  .outil-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .outil-card ul li { font-size: 0.76rem; color: var(--gris-mid); line-height: 1.4; padding-left: 0.8rem; position: relative; }
  .outil-card ul li::before { content: '›'; position: absolute; left: 0; color: var(--vert-vif); }
  .suivi-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,0.05); }
  .suivi-cell { background: rgba(11,26,11,0.4); padding: 1.3rem; text-align: center; }
  .suivi-cell .sc-t { font-size: 0.76rem; font-weight: 500; color: var(--blanc); display: block; margin-bottom: 0.3rem; }
  .suivi-cell .sc-d { font-size: 0.68rem; color: var(--gris-mid); line-height: 1.4; }

  /* AMBITIONS */
  #ambitions { background: var(--vert-fonce); }
  .ambitions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5rem; align-items: start; }
  .obj-list { display: flex; flex-direction: column; }
  .obj-item { display: grid; grid-template-columns: 5.5rem 1fr; gap: 1.5rem; padding: 1.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); align-items: start; }
  .obj-horizon { font-family: 'Impact', 'Arial Narrow', 'Franklin Gothic Medium', sans-serif; letter-spacing: 0.04em; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; padding-top: 0.15rem; }
  .obj-item:nth-child(1) .obj-horizon { color: var(--vert-vif); }
  .obj-item:nth-child(2) .obj-horizon { color: var(--or); }
  .obj-item:nth-child(3) .obj-horizon { color: var(--gris-mid); }
  .obj-title { font-weight: 500; font-size: 0.88rem; color: var(--blanc); margin-bottom: 0.3rem; }
  .obj-detail { font-size: 0.76rem; color: var(--gris-mid); line-height: 1.5; }
  .cherche { margin-bottom: 2rem; }
  .cherche .ch-title { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gris-mid); margin-bottom: 1rem; }
  .cherche-list { display: flex; flex-direction: column; gap: 0.6rem; list-style: none; }
  .cherche-list li { font-size: 0.84rem; color: var(--gris-clair); line-height: 1.4; display: flex; gap: 0.7rem; align-items: flex-start; }
  .cherche-list li::before { content: '→'; color: var(--vert-vif); flex-shrink: 0; font-size: 0.78rem; margin-top: 0.08rem; }

  /* CLÔTURE */
  #cloture { background: var(--noir); min-height: 55vh; display: flex; align-items: center; justify-content: center; }
  .cloture-inner { text-align: center; padding: 5rem 4rem; max-width: 800px; margin: 0 auto; }
  .cloture-phrase { font-family: 'Playfair Display', serif; font-style: italic; font-size: clamp(1.4rem, 2.5vw, 2.1rem); line-height: 1.45; color: var(--gris-clair); margin-bottom: 2.5rem; }
  .cloture-phrase em { color: var(--vert-vif); font-style: normal; }
  .cloture-sep { width: 2.5rem; height: 1px; background: var(--vert-vif); margin: 0 auto 2.5rem; }
  .cloture-contacts { display: flex; gap: 3rem; justify-content: center; flex-wrap: wrap; }
  .cc { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
  .cc-l { font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gris-mid); }
  .cc-v { font-size: 0.85rem; color: var(--blanc); }

  /* RESPONSIVE */
  @media (max-width: 920px) {
    .slide-inner { padding: 6rem 2rem 3rem; }
    .cover-grid, #profil .slide-inner, .parcours-grid, .identite-grid, .role-grid, .ambitions-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .outils-grid { grid-template-columns: 1fr; }
    .suivi-strip { grid-template-columns: repeat(2,1fr); }
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .stats-grid { grid-template-columns: repeat(2,1fr); }
    .preuves-grid { grid-template-columns: 1fr; }
  }

  /* ── MOTIF DIAGONAL RÉCURRENT ── */
  .slide::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;base64,");
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }
  .slide .slide-inner, .slide .cover-grid, .slide-inner > * {
    position: relative;
    z-index: 1;
  }

  /* ── NUMÉROS DE SECTION ── */
  .section-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 7rem;
    font-weight: 700;
    color: rgba(74,158,74,0.04);
    position: absolute;
    right: 4rem;
    top: 4rem;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ── SÉPARATEURS TYPOGRAPHIQUES ── */
  .slide-title::after {
    content: '';
    display: block;
    width: 3rem;
    height: 2px;
    background: linear-gradient(to right, var(--vert-vif), transparent);
    margin-top: 0.8rem;
  }

  /* ── ACCENT CITATION ── */
  .citation::before {
    content: '"';
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    color: rgba(74,158,74,0.15);
    position: absolute;
    left: -0.5rem;
    top: -1.5rem;
    line-height: 1;
  }
